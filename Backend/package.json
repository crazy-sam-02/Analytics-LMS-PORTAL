{
  "name": "backend",
  "version": "1.0.0",
  "description": "LMS Student Portal API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "postinstall": "node scripts/install-puppeteer-browser.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "create": "node scripts/create-superadmin.js",
    "reset": "node scripts/reset-superadmin-password.js",
    "verify": "node scripts/verify-superadmin.js",
    "load:exam-start": "k6 run scripts/load/exam-start-spike.k6.js",
    "load:exam-start:strict": "k6 run -e EXPECT_STATUS=200,201 scripts/load/exam-start-spike.k6.js",
    "load:exam-flow": "k6 run scripts/load/exam-flow.k6.js",
    "load:exam-flow:100": "k6 run -e PROFILE=100 scripts/load/exam-flow.k6.js",
    "load:exam-flow:500": "k6 run -e PROFILE=500 scripts/load/exam-flow.k6.js",
    "load:exam-flow:1000": "k6 run -e PROFILE=1000 scripts/load/exam-flow.k6.js",
    "load:exam-flow:2000": "k6 run -e TARGET_USERS=2000 -e WARMUP_USERS=500 -e WARMUP_DURATION=5m -e HOLD_DURATION=15m -e RAMPDOWN_DURATION=3m scripts/load/exam-flow.k6.js",
    "load:exam-flow:5000": "k6 run -e PROFILE=5000 scripts/load/exam-flow.k6.js",
    "prod:check": "node scripts/prod-readiness-check.js",
    "smoke:local-production": "node scripts/local-production-smoke.js",
    "load:exam-start:win": "\"C:\\Program Files\\k6\\k6.exe\" run scripts/load/exam-start-spike.k6.js",
    "load:exam-start:win:strict": "\"C:\\Program Files\\k6\\k6.exe\" run -e EXPECT_STATUS=200,201 scripts/load/exam-start-spike.k6.js",
    "load:exam-start:docker": "docker run --rm -i -v \"%cd%:/work\" -w /work grafana/k6 run -e BASE_URL=http://host.docker.internal:5000 scripts/load/exam-start-spike.k6.js",
    "load:exam-start:docker:strict": "docker run --rm -i -v \"%cd%:/work\" -w /work grafana/k6 run -e BASE_URL=http://host.docker.internal:5000 -e EXPECT_STATUS=200,201 scripts/load/exam-start-spike.k6.js",
    "db:migrate:admin-access-profiles": "node scripts/mongo/backfill-admin-access-profiles.js",
    "db:migrate:objectid-ids": "node scripts/mongo/migrate-objectid-ids.js",
    "db:migrate:refresh-token-hashes": "node scripts/mongo/backfill-refresh-token-hashes.js",
    "db:migrate:violations": "node scripts/mongo/backfill-violations.js",
    "db:create-indexes": "node scripts/mongo/create-indexes.js",
    "backup:mongodb": "sh scripts/backup/mongodb-backup.sh",
    "backup:uploads": "sh scripts/backup/uploads-backup.sh",
    "backup:all": "sh scripts/backup/mongodb-backup.sh && sh scripts/backup/uploads-backup.sh",
    "backup:verify": "sh scripts/backup/verify-backups.sh",
    "backup:sync": "sh scripts/backup/sync-backups.sh",
    "backup:restore-drill": "sh scripts/backup/restore-drill.sh",
    "restore:mongodb": "sh scripts/backup/mongodb-restore.sh",
    "restore:uploads": "sh scripts/backup/uploads-restore.sh",
    "test": "jest --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.58.5",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "puppeteer": "^25.1.0",
    "resend": "^6.12.4",
    "socket.io": "^4.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
