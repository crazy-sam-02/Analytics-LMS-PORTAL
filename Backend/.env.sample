PORT=5000
NODE_ENV=development
RATE_LIMIT_DISABLED=false
MONGODB_URI=mongodb://localhost:27017/lms_portal
MONGODB_DB_NAME=lms_portal
# Production Docker Compose creates this least-privilege app user on first MongoDB init.
MONGO_APP_USERNAME=lms_app
MONGO_APP_PASSWORD=
MONGO_REPLICA_SET_NAME=rs0
MONGO_REPLICA_SET_HOST=mongo:27017
MONGO_REPLICA_SET_KEY=
REQUEST_BODY_LIMIT=5mb
RESOURCE_UPLOAD_ROOT=uploads/resources
RESOURCE_MAX_FILE_SIZE_BYTES=52428800

# REQUIRED: Must be at least 32 characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@analyticsedify.com
RESEND_FROM_NAME=Analytics Edify
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_DELIVERY_MODE=response
PASSWORD_RESET_FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password
PASSWORD_RESET_ADMIN_FRONTEND_URL=http://localhost:5173/admin/reset-password
PASSWORD_RESET_COLLEGE_ADMIN_FRONTEND_URL=http://localhost:5173/college-admin/reset-password
PASSWORD_RESET_SUPER_ADMIN_FRONTEND_URL=http://localhost:5173/super-admin/reset-password
PASSWORD_RESET_RETURN_TOKEN=true
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_BIND_PORT=8080
APP_NETWORK_NAME=lms_portal_net
# Redis: Required for caching, rate limiting, Socket.IO scaling, and job queues.
# Leave empty to fall back to in-memory (single-instance only).
# Production: use rediss:// for TLS, set requirepass in Redis config.
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=false
REDIS_QUEUE_ENABLED=false
REDIS_MAXMEMORY=4gb
REDIS_MAXMEMORY_POLICY=noeviction
METRICS_ENABLED=false
METRICS_TOKEN=
METRICS_TOKEN_FILE=./deploy/monitoring/secrets/metrics_token
PROMETHEUS_BIND_PORT=9090
GRAFANA_BIND_PORT=3000
ALERTMANAGER_BIND_PORT=9093
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
ALERTMANAGER_WEBHOOK_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lms-portal

# Production backup targets. Use absolute paths on the VPS and mount/upload these
# directories to off-server storage.
BACKUP_ROOT=/var/backups/lms-portal
UPLOADS_BACKUP_ROOT=/var/backups/lms-portal/uploads
HOST_BACKUP_ROOT=/var/backups/lms-portal
BACKUP_MAX_AGE_HOURS=26
BACKUP_RCLONE_DESTINATION=
BACKUP_RCLONE_FLAGS=
BACKUP_SYNC_VERIFY=true
BACKUP_SYNC_CONFIGURED=false
BACKUP_SYNC_COMMAND=

UPLOAD_DISK_WARNING_PERCENT=80
UPLOAD_DISK_CRITICAL_PERCENT=90
UPLOAD_TMP_MAX_AGE_HOURS=24
UPLOAD_AV_SCAN_ENABLED=false
UPLOAD_AV_SCAN_REQUIRED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000
CLAMAV_STREAM_MAX_LENGTH=100M

# API rate limiting
RATE_LIMIT_GENERAL_API_WINDOW_MS=60000
RATE_LIMIT_GENERAL_API_MAX=240
RATE_LIMIT_SUPER_ADMIN_API_WINDOW_MS=60000
RATE_LIMIT_SUPER_ADMIN_API_MAX=600
RATE_LIMIT_AUTH_LOGIN_WINDOW_MS=900000
RATE_LIMIT_AUTH_LOGIN_MAX=15
RATE_LIMIT_AUTH_REFRESH_WINDOW_MS=300000
RATE_LIMIT_AUTH_REFRESH_MAX=50
RATE_LIMIT_AUTH_FORGOT_PASSWORD_WINDOW_MS=900000
RATE_LIMIT_AUTH_FORGOT_PASSWORD_MAX=5
RATE_LIMIT_AUTH_RESET_PASSWORD_WINDOW_MS=900000
RATE_LIMIT_AUTH_RESET_PASSWORD_MAX=10
RATE_LIMIT_SUPER_ADMIN_AUTH_LOGIN_WINDOW_MS=900000
RATE_LIMIT_SUPER_ADMIN_AUTH_LOGIN_MAX=5
RATE_LIMIT_SUPER_ADMIN_PASSWORD_RESET_WINDOW_MS=3600000
RATE_LIMIT_SUPER_ADMIN_PASSWORD_RESET_MAX=3
RATE_LIMIT_EXAM_START_WINDOW_MS=60000
RATE_LIMIT_EXAM_START_MAX=20
RATE_LIMIT_EXAM_LIST_WINDOW_MS=30000
RATE_LIMIT_EXAM_LIST_MAX=20
RATE_LIMIT_EXAM_SESSION_WINDOW_MS=30000
RATE_LIMIT_EXAM_SESSION_MAX=30
RATE_LIMIT_EXAM_ANSWER_WINDOW_MS=60000
RATE_LIMIT_EXAM_ANSWER_MAX=100
RATE_LIMIT_EXAM_HEARTBEAT_WINDOW_MS=60000
RATE_LIMIT_EXAM_HEARTBEAT_MAX=30
RATE_LIMIT_EXAM_VIOLATION_WINDOW_MS=60000
RATE_LIMIT_EXAM_VIOLATION_MAX=12
RATE_LIMIT_EXAM_SUBMIT_WINDOW_MS=15000
RATE_LIMIT_EXAM_SUBMIT_MAX=3
RATE_LIMIT_EVENT_REGISTER_WINDOW_MS=60000
RATE_LIMIT_EVENT_REGISTER_MAX=6
RATE_LIMIT_STUDENT_REPORT_WINDOW_MS=60000
RATE_LIMIT_STUDENT_REPORT_MAX=10
RATE_LIMIT_REPORT_GENERATION_WINDOW_MS=60000
RATE_LIMIT_REPORT_GENERATION_MAX=10
RATE_LIMIT_ADMIN_REPORT_READ_WINDOW_MS=30000
RATE_LIMIT_ADMIN_REPORT_READ_MAX=20
RATE_LIMIT_ADMIN_TEST_LIST_WINDOW_MS=30000
RATE_LIMIT_ADMIN_TEST_LIST_MAX=30
RATE_LIMIT_ADMIN_TEST_CREATE_WINDOW_MS=60000
RATE_LIMIT_ADMIN_TEST_CREATE_MAX=8
RATE_LIMIT_ADMIN_TEST_UPDATE_WINDOW_MS=60000
RATE_LIMIT_ADMIN_TEST_UPDATE_MAX=20
RATE_LIMIT_ADMIN_TEST_PUBLISH_WINDOW_MS=60000
RATE_LIMIT_ADMIN_TEST_PUBLISH_MAX=6
RATE_LIMIT_ADMIN_TEST_CLONE_WINDOW_MS=60000
RATE_LIMIT_ADMIN_TEST_CLONE_MAX=5
RATE_LIMIT_ADMIN_TEST_MONITORING_WRITE_WINDOW_MS=60000
RATE_LIMIT_ADMIN_TEST_MONITORING_WRITE_MAX=20
RATE_LIMIT_ADMIN_QUESTION_BANK_BULK_IMPORT_WINDOW_MS=300000
RATE_LIMIT_ADMIN_QUESTION_BANK_BULK_IMPORT_MAX=5
RATE_LIMIT_ADMIN_BATCH_GUARD_WINDOW_MS=60000
RATE_LIMIT_ADMIN_BATCH_GUARD_MAX=12
RATE_LIMIT_SUPER_REPORT_WINDOW_MS=60000
RATE_LIMIT_SUPER_REPORT_MAX=20
RATE_LIMIT_SUPER_REPORT_READ_WINDOW_MS=60000
RATE_LIMIT_SUPER_REPORT_READ_MAX=180
RATE_LIMIT_LEADERBOARD_WINDOW_MS=30000
RATE_LIMIT_LEADERBOARD_MAX=20
RATE_LIMIT_COLLEGE_ADMIN_API_WINDOW_MS=60000
RATE_LIMIT_COLLEGE_ADMIN_API_MAX=180
RATE_LIMIT_ADMIN_ENTITY_READ_WINDOW_MS=30000
RATE_LIMIT_ADMIN_ENTITY_READ_MAX=40
RATE_LIMIT_ADMIN_ENTITY_WRITE_WINDOW_MS=60000
RATE_LIMIT_ADMIN_ENTITY_WRITE_MAX=20
RATE_LIMIT_ADMIN_ANALYTICS_READ_WINDOW_MS=30000
RATE_LIMIT_ADMIN_ANALYTICS_READ_MAX=20
RATE_LIMIT_ADMIN_SETTINGS_WINDOW_MS=60000
RATE_LIMIT_ADMIN_SETTINGS_MAX=12
RATE_LIMIT_RESOURCE_DOWNLOAD_WINDOW_MS=60000
RATE_LIMIT_RESOURCE_DOWNLOAD_MAX=20
RATE_LIMIT_RESOURCE_SEARCH_WINDOW_MS=60000
RATE_LIMIT_RESOURCE_SEARCH_MAX=60
RATE_LIMIT_RESOURCE_UPLOAD_WINDOW_MS=60000
RATE_LIMIT_RESOURCE_UPLOAD_MAX=10
