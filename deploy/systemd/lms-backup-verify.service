[Unit]
Description=LMS Portal backup verification
Wants=docker.service
After=docker.service lms-mongodb-backup.service lms-uploads-backup.service

[Service]
Type=oneshot
WorkingDirectory=/var/www/lms-portal
Environment=ENV_FILE=/var/www/lms-portal/Backend/.env.production
ExecStart=/bin/sh /var/www/lms-portal/Backend/scripts/backup/verify-backups.sh
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
